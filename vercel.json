{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/upsell",
      "destination": "/upsell/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/upsell/:path*",
      "destination": "/upsell/:path*"
    },
    {
      "source": "/:path((?!upsell).*)",
      "destination": "/index.html"
    }
  ]
}
